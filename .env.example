################################
# Docker Compose Service Configuration
# Copy this file to .env and fill in your values
################################

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=pdf_platform
POSTGRES_DSN=postgresql://postgres:change-me-in-production@postgres:5432/pdf_platform

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MinIO (S3 Storage) Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production
MINIO_SECURE=false
MINIO_BUCKET_INPUT=input-files
MINIO_BUCKET_OUTPUT=output-files

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ClamAV Configuration
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# APP SETTINGS
APP_NAME=pdf-platform
APP_ENV=development
DEBUG=true

# SECURITY
SECRET_KEY=change-this-to-a-random-secure-key-in-production
JWT_SECRET=change-this-to-a-random-secure-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,https://localhost,https://localhost:443

# File Upload Configuration
MAX_FILE_SIZE=104857600
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,gif,bmp
UPLOAD_DIRECTORY=/tmp/uploads
STORAGE_PATH=/data/uploads
TEMP_PATH=/tmp/processing

# BREVO EMAIL SMTP (For Notifications)
SMTP_SERVER=smtp-relay.brevo.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-email@example.com
SMTP_USER=your-brevo-email@example.com
SMTP_PASSWORD=your-brevo-password
SMTP_FROM_EMAIL=noreply@pdf-platform.example.com

# PAYMOB PAYMENT (For Egyptian Market)
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_HMAC_SECRET=your-paymob-hmac-secret
PAYMOB_INTEGRATION_CARD=your-card-integration-id
PAYMOB_INTEGRATION_WALLET=your-wallet-integration-id
PAYMOB_TEST_MODE=true

# DOMAIN / URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_API=30/minute

# Monitoring & Metrics
ENABLE_METRICS=true
METRICS_PORT=8001

# Database Migrations
RUN_MIGRATIONS=true

# Environment
ENVIRONMENT=development
